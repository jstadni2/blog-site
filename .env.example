# Copy this file to .env and fill in your values before running in production.

# Flask secret key — MUST be changed to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# Admin credentials
ADMIN_USERNAME=admin

# Generate a bcrypt hash with:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
# Then paste the result below.
ADMIN_PASSWORD_HASH=

# Flask environment
FLASK_APP=src.blogsite:app
FLASK_DEBUG=0

# DynamoDB settings
# For local development with Docker Compose, use http://localhost:8000
DYNAMODB_TABLE_NAME=blog_posts
DYNAMODB_ENDPOINT_URL=http://localhost:8000
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
