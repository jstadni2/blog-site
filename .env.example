# Copy this file to .env and fill in your values before running in production.

# Flask secret key — MUST be changed to a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# Admin credentials
ADMIN_USERNAME=admin

# Generate a bcrypt hash with:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
# Then paste the result below.
ADMIN_PASSWORD_HASH=

# Flask environment
FLASK_APP=app.py
FLASK_DEBUG=0
